---
/*
 * /pricing/ — subscription pricing page (localized).
 *
 * Card LAYOUT + COPY mirror the vela subscription modal (`pricing-plans.tsx`).
 * The NUMBERS come from `PRICING_SNAPSHOT` at build time and are reconciled
 * from `PLANS_JSON_URL` by the inline script after validating the public JSON
 * contract. The localized TEXT comes from app/_lib/pricing-content.ts.
 * Numbers and text are kept separate on purpose: only numbers are part of the
 * plans.json contract.
 */
import Layout from '../../_components/sub-page-layout.astro';
import {
  PRICING_SNAPSHOT,
  PLANS_JSON_URL,
  CLOUD_CONSOLE_URL,
  cloudSubscribeUrl,
  type PlanTierConfig,
} from '../../_lib/pricing';
import {
  getPricingContent,
  fillTemplate,
  PREMIUM_MODELS,
  STANDARD_MODELS,
  type PlanTierId,
} from '../../_lib/pricing-content';
import {
  getStory,
  getFaqs,
  getFaqTitle,
  getEnterprise,
  ENTERPRISE_EMAIL,
} from '../../_lib/pricing-extras-content';
import { getCatalogCounts } from '../../_lib/catalog';
import { localeFromPath, localizedHref } from '../../i18n';

const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => localizedHref(path, locale);
const content = getPricingContent(locale);
const L = content.labels;
const catalogCounts = await getCatalogCounts(locale);
const catalogLabelVars = {
  skillsCount: catalogCounts.skills.toLocaleString('en-US'),
  systemsCount: catalogCounts.systems.toLocaleString('en-US'),
};

// Footer line with the cloud-console link injected into the localized
// template. Brand/URL only — safe to render as HTML.
const footnoteHtml = fillTemplate(L.footnote, {
  console: `<a class="inline-link" href="${CLOUD_CONSOLE_URL}">${L.consoleLabel}</a>`,
});

// Customer story + FAQ below the cards (mirrors vela's modal). "Read more"
// points at the marketing site's own Ikigai One story page.
const story = getStory(locale);
const faqs = getFaqs(locale);
const faqTitle = getFaqTitle(locale);
const storyMoreHref = href('/stories/ikigai-one/');
const enterprise = getEnterprise(locale);

const SITE = Astro.site?.toString() ?? 'https://open-design.ai/';
const title = 'Pricing — Open Design';
const description =
  'Open Design subscription plans. Plus, Pro, and Max tiers with monthly credits, one-click deployments, and auto top-up — one unified balance for every Open Design call.';

const tiers: PlanTierConfig[] = PRICING_SNAPSHOT.tiers;
const usd = (n: number) => `$${Math.round(n).toLocaleString('en-US')}`;
const renderCatalogLabel = (label: string) => fillTemplate(label, catalogLabelVars);

// Build-time display values per tier (the inline script recomputes these from
// the public plans.json using the same formulas + the same label templates).
function view(t: PlanTierConfig) {
  const introPct = Math.round((1 - t.monthly.introPriceUsd / t.monthly.priceUsd) * 100);
  const yearlyEquiv = Math.round(t.yearly.priceUsd / 12);
  const yearlySave = t.monthly.priceUsd * 12 - t.yearly.priceUsd;
  return {
    monthly: {
      amount: usd(t.monthly.introPriceUsd),
      strike: usd(t.monthly.priceUsd),
      tag: fillTemplate(L.firstMonthTag, { pct: String(introPct) }),
      subline: fillTemplate(L.monthlyRenewal, { amountUsd: usd(t.monthly.priceUsd) }),
    },
    yearly: {
      amount: usd(yearlyEquiv),
      strike: usd(t.monthly.priceUsd),
      tag: fillTemplate(L.yearlyDiscountTag, { pct: String(t.yearly.discountPct) }),
      subline: fillTemplate(L.yearlySubline, {
        totalUsd: usd(t.yearly.priceUsd),
        savingsUsd: usd(yearlySave),
      }),
    },
    credits: `${usd(t.monthly.grantUsd)}${L.perMonth}`,
  };
}

const absUrl = (path: string) => new URL(href(path), SITE).toString();
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Open Design', item: absUrl('/') },
      { '@type': 'ListItem', position: 2, name: 'Pricing', item: absUrl('/pricing/') },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Open Design Subscription',
    description,
    offers: tiers.map((t) => ({
      '@type': 'Offer',
      name: `Open Design ${t.tier}`,
      price: String(t.monthly.priceUsd),
      priceCurrency: 'USD',
      url: CLOUD_CONSOLE_URL,
    })),
  },
];
---

<Layout title={title} description={description} active="pricing" jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={href('/')}>Open Design</a>
    <span>/</span>
    <span aria-current="page">Pricing</span>
  </nav>

  <article class="info-page pr-page" data-pricing-root data-interval="monthly">
    <header class="pr-hero">
      <h1 class="pr-hero-heading">{L.heroTitle}</h1>
      <div class="pr-toggle" role="tablist" aria-label="Billing interval">
        <button type="button" class="pr-toggle-btn is-active" role="tab" data-interval-btn="monthly" aria-selected="true">
          {L.monthly}
        </button>
        <button type="button" class="pr-toggle-btn" role="tab" data-interval-btn="yearly" aria-selected="false">
          {L.yearly}
          <span class="pr-toggle-save">{L.yearlySave}</span>
        </button>
      </div>
    </header>

    <section class="pr-grid" aria-label="Subscription plans">
      {tiers.map((t) => {
        const v = view(t);
        const plan = content.plans[t.tier as PlanTierId];
        return (
          <article class="pr-card" data-tier={t.tier} data-recommended={t.recommended ? 'true' : undefined}>
            <header class="pr-head">
              <img
                class="pr-tier-logo"
                src={`/pricing/plan-${t.tier}.svg`}
                alt={t.tier.charAt(0).toUpperCase() + t.tier.slice(1)}
                height={22}
                loading="lazy"
                decoding="async"
              />
              <p class="pr-tagline">{plan.tagline}</p>
            </header>

            <div class="pr-price">
              <div class="pr-when" data-when="monthly">
                <div class="pr-price-row">
                  <span class="pr-amount" data-od-amount>{v.monthly.amount}</span>
                  <s class="pr-strike" data-od-strike>{v.monthly.strike}</s>
                  <span class="pr-per">{L.perMonth}</span>
                  <span class="pr-tag" data-od-tag>{v.monthly.tag}</span>
                </div>
                <p class="pr-subline" data-od-subline>{v.monthly.subline}</p>
              </div>
              <div class="pr-when" data-when="yearly">
                <div class="pr-price-row">
                  <span class="pr-amount" data-od-amount>{v.yearly.amount}</span>
                  <s class="pr-strike" data-od-strike>{v.yearly.strike}</s>
                  <span class="pr-per">{L.perMonth}</span>
                  <span class="pr-tag" data-od-tag>{v.yearly.tag}</span>
                </div>
                <p class="pr-subline" data-od-subline>{v.yearly.subline}</p>
              </div>
            </div>

            <div class="pr-metrics">
              <div class="pr-metric">
                <span class="pr-metric-label">{L.modelCredits}</span>
                <span class="pr-metric-val" data-od-credit>{v.credits}</span>
              </div>
              <div class="pr-metric">
                <span class="pr-metric-label">{L.deliverablesLabel}</span>
                <span class="pr-metric-val">{plan.deliverablesValue}</span>
              </div>
            </div>

            <p class="pr-anchor">{plan.costAnchor}</p>

            <a
              class={t.recommended ? 'btn btn-primary pr-cta' : 'btn btn-ghost pr-cta'}
              href={cloudSubscribeUrl(t.tier, 'monthly')}
              data-pricing-cta
              data-tier={t.tier}
            >
              {plan.ctaLabel}
            </a>

            <ul class="pr-feats">
              {plan.features.map((f) =>
                f.heading ? (
                  <li class="pr-feat-head">{renderCatalogLabel(f.label)}</li>
                ) : (
                  <li class="pr-feat">{renderCatalogLabel(f.label)}</li>
                ),
              )}
            </ul>

            <div class="pr-models">
              <p class="pr-models-head">{L.premiumModels}</p>
              <ul class="pr-model-list">
                {PREMIUM_MODELS.map((m) => <li>{m}</li>)}
              </ul>
              <p class="pr-models-head">{L.standardModels}</p>
              <ul class="pr-model-list">
                {STANDARD_MODELS.map((m) => <li>{m}</li>)}
              </ul>
            </div>
          </article>
        );
      })}
    </section>

    <p class="pr-foot" set:html={footnoteHtml} />
  </article>

  <section class="pr-team" aria-label={enterprise.title}>
    <div class="pr-team-row">
      <div class="pr-team-lead">
        <span class="pr-team-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 21h18" />
            <path d="M5 21V7l7-4 7 4v14" />
            <path d="M9 9h.01M9 13h.01M9 17h.01M15 9h.01M15 13h.01M15 17h.01" />
          </svg>
        </span>
        <div>
          <div class="pr-team-head">
            <h3 class="pr-team-title">{enterprise.title}</h3>
            <span class="pr-team-badge">{enterprise.badge}</span>
          </div>
          <p class="pr-team-desc">{enterprise.description}</p>
        </div>
      </div>
      <div class="pr-team-actions">
        <a class="btn btn-primary pr-team-cta" href={`mailto:${ENTERPRISE_EMAIL}`}>
          {enterprise.leadCta}
        </a>
        <a class="pr-team-email" href={`mailto:${ENTERPRISE_EMAIL}`}>
          <span aria-hidden="true">✉</span> {ENTERPRISE_EMAIL}
        </a>
      </div>
    </div>
    <ul class="pr-team-feats">
      {enterprise.features.map((f) => <li>{f}</li>)}
    </ul>
  </section>

  <section class="pr-story" aria-label={story.eyebrow}>
    <div class="pr-story-head">
      <p class="pr-story-eyebrow">{story.eyebrow}</p>
      <a class="pr-story-more" href={storyMoreHref}>
        {story.more}<span aria-hidden="true"> →</span>
      </a>
    </div>
    <div class="pr-story-card">
      <div class="pr-story-body">
        <blockquote class="pr-story-quote">
          <span class="pr-q" aria-hidden="true">“</span>{story.quote.lead}<span class="pr-hl">{story.quote.highlight}</span>{story.quote.tail}<span class="pr-q" aria-hidden="true">”</span>
        </blockquote>
        <div class="pr-story-person">
          <span class="pr-story-avatar" aria-hidden="true">I</span>
          <div>
            <div class="pr-story-name">{story.name}</div>
            <div class="pr-story-role">{story.role}</div>
          </div>
        </div>
        <div class="pr-story-chips">
          {story.chips.map((chip) => <span class="pr-chip">{chip}</span>)}
        </div>
        <div class="pr-story-stats">
          {story.stats.map((stat) => (
            <div class="pr-stat">
              <div class="pr-stat-val">{stat.value}</div>
              <div class="pr-stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
      <img
        class="pr-story-cover"
        src="/stories/ikigai-one-cover.webp"
        alt={`${story.name} — ${story.role}`}
        width={800}
        height={450}
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>

  <section class="pr-faq" aria-label={faqTitle}>
    <h2 class="pr-faq-title">{faqTitle}</h2>
    <div class="pr-faq-list">
      {faqs.map((faq) => (
        <details class="pr-faq-item">
          <summary class="pr-faq-q">{faq.q}</summary>
          <div class="pr-faq-a">{faq.a}</div>
        </details>
      ))}
    </div>
  </section>

  <script is:inline define:vars={{ plansUrl: PLANS_JSON_URL, labels: L, subscribeBase: CLOUD_CONSOLE_URL }}>
    (() => {
      const root = document.querySelector('[data-pricing-root]');
      if (!root) return;

      // Keep each plan's CTA deep-link pointing at the cloud console with the
      // currently selected billing interval. The console is auth-gated and
      // resumes this same intent after login; checkout=auto asks it to open
      // Stripe checkout for the tier immediately.
      const syncCtas = (interval) => {
        for (const cta of root.querySelectorAll('[data-pricing-cta]')) {
          const tier = cta.getAttribute('data-tier') || '';
          const q = new URLSearchParams({ view: 'plans', plan: tier, interval, checkout: 'auto' });
          cta.setAttribute('href', subscribeBase + '?' + q.toString());
        }
      };

      // ── Billing interval toggle ──────────────────────────────────────────
      for (const btn of root.querySelectorAll('[data-interval-btn]')) {
        btn.addEventListener('click', () => {
          const interval = btn.getAttribute('data-interval-btn');
          root.setAttribute('data-interval', interval);
          for (const b of root.querySelectorAll('[data-interval-btn]')) {
            const on = b === btn;
            b.classList.toggle('is-active', on);
            b.setAttribute('aria-selected', on ? 'true' : 'false');
          }
          syncCtas(interval);
        });
      }

      // ── Pricing contract reconciliation ──────────────────────────────────
      // Same formulas + same label templates as the build-time render, applied
      // to the published JSON contract. Falls back to the baked snapshot.
      const usd = (n) => '$' + Math.round(n).toLocaleString('en-US');
      const fill = (tpl, vals) => tpl.replace(/\{(\w+)\}/g, (_, k) => (k in vals ? vals[k] : '{' + k + '}'));
      const set = (scope, sel, text) => {
        const el = root.querySelector(scope + ' ' + sel);
        if (el) el.textContent = text;
      };

      fetch(plansUrl, { headers: { Accept: 'application/json' } })
        .then((r) => {
          const contentType = r.headers.get('content-type') || '';
          return r.ok && contentType.includes('application/json') ? r.json() : null;
        })
        .then((data) => {
          if (!data || !Array.isArray(data.tiers)) return;
          for (const t of data.tiers) {
            if (!t || typeof t.tier !== 'string' || !t.monthly || !t.yearly) continue;
            const card = '[data-tier="' + t.tier + '"]';
            const introPct = Math.round((1 - t.monthly.introPriceUsd / t.monthly.priceUsd) * 100);
            const yearlyEquiv = Math.round(t.yearly.priceUsd / 12);
            const yearlySave = t.monthly.priceUsd * 12 - t.yearly.priceUsd;

            set(card, '[data-when="monthly"] [data-od-amount]', usd(t.monthly.introPriceUsd));
            set(card, '[data-when="monthly"] [data-od-strike]', usd(t.monthly.priceUsd));
            set(card, '[data-when="monthly"] [data-od-tag]', fill(labels.firstMonthTag, { pct: String(introPct) }));
            set(card, '[data-when="monthly"] [data-od-subline]', fill(labels.monthlyRenewal, { amountUsd: usd(t.monthly.priceUsd) }));

            set(card, '[data-when="yearly"] [data-od-amount]', usd(yearlyEquiv));
            set(card, '[data-when="yearly"] [data-od-strike]', usd(t.monthly.priceUsd));
            set(card, '[data-when="yearly"] [data-od-tag]', fill(labels.yearlyDiscountTag, { pct: String(t.yearly.discountPct) }));
            set(card, '[data-when="yearly"] [data-od-subline]', fill(labels.yearlySubline, { totalUsd: usd(t.yearly.priceUsd), savingsUsd: usd(yearlySave) }));

            set(card, '[data-od-credit]', usd(t.monthly.grantUsd) + labels.perMonth);
          }
        })
        .catch(() => {});

      // CTA analytics.
      root.addEventListener('click', (event) => {
        const cta = event.target && event.target.closest && event.target.closest('[data-pricing-cta]');
        if (!cta) return;
        try {
          const props = {
            page_name: 'pricing',
            tier: cta.getAttribute('data-tier') || 'unknown',
            interval: root.getAttribute('data-interval') || 'monthly',
          };
          if (typeof window.__odTrack === 'function') window.__odTrack('pricing_subscribe_click', props);
          else if (window.posthog && window.posthog.capture) window.posthog.capture('pricing_subscribe_click', props);
        } catch (e) {}
      });
    })();
  </script>
</Layout>

<style>
  /* ---- Hero ---- */
  .pr-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 8px;
  }
  .pr-hero-heading {
    font-family: var(--serif, Georgia, serif);
    font-weight: 600;
    font-size: clamp(28px, 4.2vw, 42px);
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* ---- Billing toggle ---- */
  .pr-toggle {
    margin-top: 22px;
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border-radius: 999px;
    border: 1px solid var(--border, rgba(0, 0, 0, 0.12));
    background: var(--surface, rgba(255, 255, 255, 0.5));
  }
  .pr-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 0;
    background: transparent;
    cursor: pointer;
    font: inherit;
    font-size: 0.9rem;
    color: var(--ink-soft, #555);
    padding: 8px 18px;
    border-radius: 999px;
    transition: background-color 200ms cubic-bezier(0.23, 1, 0.32, 1), color 200ms;
  }
  .pr-toggle-btn.is-active { background: var(--ink); color: #fff; }
  .pr-toggle-save {
    font-size: 0.66rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    background: var(--brand, #2bd200);
    color: #103600;
    white-space: nowrap;
  }

  /* ---- Interval-conditional visibility ---- */
  [data-pricing-root][data-interval='monthly'] [data-when='yearly'] { display: none !important; }
  [data-pricing-root][data-interval='yearly'] [data-when='monthly'] { display: none !important; }

  /* ---- Grid ---- */
  .pr-grid {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1180px;
    margin-inline: auto;
    align-items: stretch;
  }
  @media (max-width: 880px) {
    .pr-grid { grid-template-columns: 1fr; max-width: 460px; }
  }

  .pr-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border, rgba(0, 0, 0, 0.12));
    border-radius: 18px;
    padding: 28px 24px 26px;
    background: var(--surface, rgba(255, 255, 255, 0.55));
    transition: border-color 200ms cubic-bezier(0.23, 1, 0.32, 1), box-shadow 200ms;
  }
  .pr-card[data-recommended='true'] {
    border-color: var(--ink);
    box-shadow: 0 0 0 1px var(--ink), 0 22px 48px -30px rgba(0, 0, 0, 0.5);
  }

  /* ---- Head ---- */
  /* Plan wordmark logo — kept 1:1 with the cloud subscription modal's
     plan-<tier>-vip.svg assets (copied to public/pricing/). */
  .pr-tier-logo {
    height: 22px;
    width: auto;
    display: block;
  }
  .pr-tagline {
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--ink-soft, #777);
    margin: 8px 0 0;
    min-height: 2.4em;
  }

  /* ---- Price ---- */
  .pr-price { margin: 18px 0 0; min-height: 74px; }
  .pr-price-row { display: flex; align-items: baseline; flex-wrap: wrap; gap: 6px; }
  .pr-amount {
    font-family: var(--serif, Georgia, serif);
    font-weight: 600;
    font-size: 2.5rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .pr-strike { font-size: 1rem; color: var(--ink-soft, #aaa); text-decoration: line-through; }
  .pr-per { font-size: 0.9rem; color: var(--ink-soft, #777); }
  .pr-tag {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.16rem 0.5rem;
    border-radius: 6px;
    background: var(--brand, #2bd200);
    color: #0d3300;
    white-space: nowrap;
  }
  .pr-subline { margin: 8px 0 0; font-size: 0.8rem; color: var(--ink-soft, #777); }

  /* ---- Metrics ---- */
  .pr-metrics {
    margin: 18px 0 0;
    padding: 16px 0;
    border-top: 1px solid var(--line, rgba(0, 0, 0, 0.08));
    border-bottom: 1px solid var(--line, rgba(0, 0, 0, 0.08));
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .pr-metric { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
  .pr-metric-label { font-size: 0.84rem; color: var(--ink-soft, #666); }
  .pr-metric-val { font-size: 0.86rem; font-weight: 650; color: var(--ink); white-space: nowrap; }

  /* ---- Cost anchor ---- */
  .pr-anchor {
    margin: 16px 0 0;
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--olive, #218c00);
  }

  /* ---- CTA ---- */
  .pr-cta { margin-top: 18px; width: 100%; justify-content: center; text-align: center; }

  /* ---- Features ---- */
  .pr-feats { list-style: none; margin: 24px 0 0; padding: 0; display: flex; flex-direction: column; gap: 11px; }
  .pr-feat-head { font-size: 0.9rem; font-weight: 650; color: var(--ink); }
  .pr-feat {
    position: relative;
    padding-left: 22px;
    font-size: 0.86rem;
    line-height: 1.45;
    color: var(--ink, #1a1a1a);
  }
  .pr-feat::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    font-weight: 700;
    color: var(--olive, #218c00);
  }

  /* ---- Model lists ---- */
  .pr-models { margin-top: 22px; }
  .pr-models-head {
    margin: 18px 0 10px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft, #999);
  }
  .pr-models-head:first-child { margin-top: 0; }
  .pr-model-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 9px; }
  .pr-model-list li {
    position: relative;
    padding-left: 22px;
    font-size: 0.85rem;
    color: var(--ink, #2a2a2a);
  }
  .pr-model-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    font-weight: 700;
    color: var(--olive, #218c00);
  }

  /* ---- Footnote ---- */
  .pr-foot {
    margin: 40px auto 0;
    max-width: 640px;
    text-align: center;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--ink-soft, #666);
  }

  /* ---- Team / enterprise banner ---- */
  .pr-team {
    max-width: 1180px;
